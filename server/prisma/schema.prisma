// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Category ────────────────────────────────────────────────────────
// Pre-seeded categories for income and expense classification.
// Each category has a visual identity (icon + color) for charts and UI.
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String   // emoji or icon identifier
  color     String   // hex color code (e.g., "#4F46E5")
  type      String   @default("EXPENSE") // "INCOME" | "EXPENSE" | "BOTH"
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  transactions Transaction[]
  budgets      Budget[]
}

// ─── Transaction ─────────────────────────────────────────────────────
// Core financial record — every income or expense entry.
model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  type        String   // "INCOME" or "EXPENSE"
  date        DateTime
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  goalId      String?
  goal        Goal?    @relation(fields: [goalId], references: [id])
}



// ─── Budget ──────────────────────────────────────────────────────────
// Monthly spending cap per category (e.g., max $200 for Dining).
// `spent` is cached and recalculated on transaction mutations.
model Budget {
  id         String   @id @default(cuid())
  limit      Float    // maximum budget amount
  month      Int      // 1–12
  year       Int
  spent      Float    @default(0) // cached sum of expenses
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, month, year])
  @@index([month, year])
}

// ─── Goal ────────────────────────────────────────────────────────────
// Savings target with a deadline and visual tracking.
model Goal {
  id            String   @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float    @default(0) // cached sum of contributions
  deadline      DateTime?
  color         String   @default("#6366F1")
  icon          String   @default("🎯")
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contributions GoalContribution[]
  transactions  Transaction[]
}

// ─── GoalContribution ────────────────────────────────────────────────
// Individual payment toward a savings goal.
model GoalContribution {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @default(now())
  note      String   @default("")
  goalId    String
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

// ─── Task ────────────────────────────────────────────────────────────
// Financial to-do items and reminders.
model Task {
  id             String   @id @default(cuid())
  title          String
  description    String   @default("")
  dueDate        DateTime?
  completed      Boolean  @default(false)
  priority       String   @default("MEDIUM") // "LOW" | "MEDIUM" | "HIGH"
  recurring      Boolean  @default(false)
  recurrenceRule String?  // "DAILY" | "WEEKLY" | "MONTHLY" | "YEARLY"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
